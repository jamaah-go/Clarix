# CLARIX Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# APPLICATION
# ============================================================================

APP_NAME=CLARIX API
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# ============================================================================
# SERVER
# ============================================================================

HOST=0.0.0.0
PORT=8000
WORKERS=4

# ============================================================================
# SUPABASE
# ============================================================================

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ============================================================================
# DATABASE
# ============================================================================

DATABASE_URL=postgresql://user:password@host:5432/clarix

# ============================================================================
# REDIS (Upstash)
# ============================================================================

REDIS_URL=redis://default:password@host:port
REDIS_MAX_CONNECTIONS=10

# ============================================================================
# PINECONE
# ============================================================================

PINECONE_API_KEY=your-pinecone-key
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=clarix-embeddings
PINECONE_NAMESPACE_PREFIX=tenant_

# ============================================================================
# LLM PROVIDERS
# ============================================================================

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Model Configuration
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
DEFAULT_EXTRACTION_MODEL=claude-sonnet-4-20250514
REASONING_MODEL=claude-opus-4-20250514

# ============================================================================
# AWS (Textract)
# ============================================================================

AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1

# ============================================================================
# STRIPE
# ============================================================================

STRIPE_API_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ============================================================================
# SENTRY
# ============================================================================

SENTRY_DSN=https://...

# ============================================================================
# SECURITY
# ============================================================================

SECRET_KEY=your-secret-key-min-32-chars-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============================================================================
# RATE LIMITING
# ============================================================================

RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=20

# ============================================================================
# DOCUMENT PROCESSING
# ============================================================================

MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=pdf,docx,doc,txt
OCR_TIMEOUT_SECONDS=300
CHUNK_OVERLAP_TOKENS=100
CHUNK_MAX_TOKENS=2000

# ============================================================================
# FEATURE FLAGS
# ============================================================================

ENABLE_OCR_FALLBACK=true
ENABLE_LLM_CACHING=true
ENABLE_AUDIT_LOGGING=true
